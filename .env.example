# ─── Required ──────────────────────────────────────────────────────────────────

# CKPool data source: a single HTTPS URL or a local CKPool log path.
# For multiple pools of the same coin, use a JSON array (optional per-pool labels):
#   API_URL='[{"url":"https://na.example.org","label":"NA"},{"url":"/var/log/ckpool-eu","label":"EU"}]'
API_URL="https://solo.ckpool.org"

# PostgreSQL connection
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="ckstats"
DB_PASSWORD="yourpassword"
DB_NAME="ckstats"

# ─── Optional (defaults shown; uncomment to override) ────────────────────────────

# Ingestion driver: unset/0 = external cron; 1 = in-process loop. See README "Enable Ingestion".
# POOL_INGEST="0"
# POOL_INGEST_INTERVAL_SECONDS="60"
# POOL_USERS_INTERVAL_SECONDS="60"   # how often the per-user half runs; the status half runs every cycle
# POOL_INGEST_CYCLE_TIMEOUT_SECONDS="120"
# POOL_CLEANUP_INTERVAL_SECONDS="7200"   # 0 = disable in-loop prune, run the cleanup script via cron
# POOL_HEALTH_STALE_SECONDS="300"

# Diagnostics
# DEBUG_ENDPOINTS="false"   # "true" enables /api/debug/* (e.g. /api/debug/user/<address> live-probes each pool)

# New-user activation rate limit: at most USER_SIGNUP_LIMIT new users created within the trailing
# USER_SIGNUP_WINDOW_SECONDS; further activations get HTTP 429 until the window clears.
# USER_SIGNUP_LIMIT="30"
# USER_SIGNUP_WINDOW_SECONDS="180"

# Outbound HTTP request headers (HTTP sources only)
# API_USER_AGENT="ckstats/1.0"
# API_TOKEN=""
# API_EXTRA_HEADERS='{"X-Pool-Key":"abc"}'
# API_REQUEST_TIMEOUT_SECONDS="5"

# HTTP keep-alive connection-pool tuning (HTTP sources only)
# API_MAX_CONNS="4"
# API_KEEPALIVE_TIMEOUT_SECONDS="30"
# API_CONNECT_TIMEOUT_SECONDS="5"
# API_TCP_KEEPALIVE_SECONDS="30"
# API_CONN_MAX_AGE_SECONDS="300"

# Database SSL
# DB_SSL="false"
# DB_SSL_REJECT_UNAUTHORIZED="false"

# Display / branding
# COIN="BTC"
# SITE_NAME="CKStats"
# MEMPOOL_LINK_TAG="solock"
# DEFAULT_THEME="dark"
# DONATION_ADDRESS="your_wallet_address_here"

# ─── Content visibility ──────────────────────────────────────────────────────────
# Hide UI elements by setting a flag to "true". Everything is shown by default.
# Naming: HIDE_<PAGE>_<CARD>_<METRIC>_<SUBTEXT> — a hyphen joins the words of one label,
# an underscore steps down a tier. Homepage flags have no page prefix; user/worker pages
# use HIDE_USER_ / HIDE_WORKER_. Setting a parent hides all of its children (e.g.
# HIDE_HASHRATES hides the whole card; HIDE_WORK-SUBMITTED_REJECTED hides one box;
# HIDE_WORK-SUBMITTED_REJECTED_PERCENTAGE hides just its subtext). A card/section whose
# children are all hidden collapses and the layout reflows.

# Homepage — cards
# HIDE_STATS-SERVICE="true"
#   HIDE_STATS-SERVICE_STREAMS / _LAST-UPDATE
# HIDE_POOL-SERVICE="true"
#   HIDE_POOL-SERVICE_UPTIME / _LAST-UPDATE
# HIDE_CONNECTIONS="true"
#   HIDE_CONNECTIONS_USERS (_IDLE) / HIDE_CONNECTIONS_WORKERS (_DISCONNECTED)
# HIDE_WORK-SUBMITTED="true"
#   HIDE_WORK-SUBMITTED_EFFORT / _ACCEPTED (_PERCENTAGE) / _REJECTED (_PERCENTAGE)
# HIDE_SHARE-COUNTS="true"
#   HIDE_SHARE-COUNTS_TOTAL / _ACCEPTED (_PERCENTAGE) / _REJECTED (_PERCENTAGE)
# HIDE_DIFFICULTY="true"
#   HIDE_DIFFICULTY_NET-DIFF / _BEST-DIFF (_PROXIMITY) / _AVG-TIME
# HIDE_SHARES-PER-SECOND="true"
#   HIDE_SHARES-PER-SECOND_1M / _5M / _15M / _1H
# HIDE_HASHRATES="true"
#   HIDE_HASHRATES_1M / _5M / _15M / _1HR / _6HR / _1D / _7D

# Homepage — sections
# HIDE_CHART="true"
# HIDE_LEADERBOARDS="true"
#   HIDE_LEADERBOARDS_DIFFICULTIES / _HASHRATES / _LOYALTY
# HIDE_HIGH-SCORES="true"
# HIDE_ONLINE-DEVICES="true"

# User page
# HIDE_USER_CONNECTION="true"
#   HIDE_USER_CONNECTION_WORKERS (_TOTAL) / _AUTHORISED / _LAST-SHARE
# HIDE_USER_DIFFICULTY="true"
#   HIDE_USER_DIFFICULTY_ACCEPTED-WORK (_EFFORT) / _BEST-DIFF (_PROXIMITY) / _BEST-EVER (_PROXIMITY)
# HIDE_USER_HASHRATES="true"
#   HIDE_USER_HASHRATES_5M / _1HR / _1D / _7D  (each + _CHANGE for its % subtext)
# HIDE_USER_ODDS="true"
#   HIDE_USER_ODDS_1-DAY / _1-WEEK / _1-MONTH / _1-YEAR
# HIDE_USER_CHART="true"
# HIDE_USER_WORKERS="true"

# Worker page
# HIDE_WORKER_CONNECTION="true"
#   HIDE_WORKER_CONNECTION_CLIENT / _UPTIME / _LAST-SHARE
# HIDE_WORKER_DIFFICULTY="true"
#   HIDE_WORKER_DIFFICULTY_ACCEPTED-WORK (_EFFORT) / _BEST-DIFF (_PROXIMITY) / _BEST-EVER (_PROXIMITY)
# HIDE_WORKER_HASHRATES="true"
#   HIDE_WORKER_HASHRATES_1M / _5M / _1HR / _1D / _7D  (each + _CHANGE for its % subtext)
# HIDE_WORKER_CHART="true"
# HIDE_WORKER_TABLE="true"
#   HIDE_WORKER_TABLE_NAME / _CLIENT / _HASHRATE-5M / _HASHRATE-1HR / _HASHRATE-1D
#   _ACCEPTED-WORK / _BEST-DIFF / _BEST-EVER / _LAST-SHARE / _UPTIME
